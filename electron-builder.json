{
  "appId": "it.routeroom.desktop",
  "productName": "Routeroom",
  "directories": {
    "output": "release"
  },
  "files": [
    "desktop/**/*",
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      "nsis"
    ]
  },
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  }
}
