{
  "appId": "it.routeroom.desktop",
  "productName": "Routeroom",
  "directories": {
    "output": "release"
  },
  "files": [
    "desktop/**/*",
    "dist/**/*",
    "package.json",
    "!**/*.map",
    "!**/{test,tests,__tests__,powered-test}/**",
    "!**/{example,examples}/**",
    "!**/{docs,doc}/**",
    "!**/{README,README.md,CHANGELOG,CHANGELOG.md,*.md}"
  ],
  "win": {
    "target": [
      "nsis"
    ]
  },
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  }
}
